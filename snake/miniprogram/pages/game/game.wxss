.page {
  padding: 16rpx;
  background: #0b1020;
  color: #e6e8ef;
  min-height: 100vh;
}

.topbar {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.title {
  font-size: 36rpx;
  font-weight: 700;
}

.hud {
  display: flex;
  gap: 24rpx;
  color: #9aa4b2;
  font-size: 24rpx;
  flex-wrap: wrap;
}

.board {
  width: 680rpx;
  height: 680rpx;
  background: #070a14;
  border: 2rpx solid #22305e;
  border-radius: 20rpx;
}

.panel {
  margin-top: 16rpx;
  padding: 16rpx;
  border: 2rpx solid #22305e;
  border-radius: 20rpx;
  background: #111833;
}

.actions {
  display: flex;
  gap: 16rpx;
}

.btn {
  flex: 1;
  background: #0c1430;
  color: #e6e8ef;
  border: 2rpx solid #2b3a70;
  border-radius: 20rpx;
  font-size: 26rpx;
}

.controls {
  margin-top: 16rpx;
}

.row {
  display: flex;
  justify-content: center;
  gap: 16rpx;
  margin-top: 12rpx;
}

.dir {
  width: 140rpx;
  height: 96rpx;
  line-height: 96rpx;
  text-align: center;
  background: #0c1430;
  color: #e6e8ef;
  border: 2rpx solid #2b3a70;
  border-radius: 20rpx;
  font-size: 36rpx;
}

.tips {
  margin-top: 14rpx;
  color: #9aa4b2;
  font-size: 24rpx;
}
